{
  "redirects": [
    {
      "source": "http://crkdev.com/:path*",
      "destination": "https://www.crkdev.com/:path*",
      "permanent": true
    },
    {
      "source": "https://crkdev.com/:path*",
      "destination": "https://www.crkdev.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
