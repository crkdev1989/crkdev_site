{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "crkdev.com" }],
      "destination": "https://www.crkdev.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
